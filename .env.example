# =============================================================================
#  .env.example — пример окружения для price-tracker.
#  Скопируй в .env (`cp .env.example .env`) и поправь секреты под себя.
#  Дефолты ниже рассчитаны на запуск через docker compose
#  (POSTGRES_HOST=db, брокер/бэкенд — сервис redis).
# =============================================================================

# --- Django ------------------------------------------------------------------
# Локальный dev-ключ для запуска из коробки. В ПРОДЕ обязательно замени на свой:
#   python -c "from django.core.management.utils import get_random_secret_key as g; print(g())"
DJANGO_SECRET_KEY=dev-local-only-replace-in-production-7f3c9a1e2b
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,web

# --- PostgreSQL --------------------------------------------------------------
POSTGRES_DB=pricetracker
POSTGRES_USER=pricetracker
POSTGRES_PASSWORD=pricetracker
# В docker compose имя сервиса БД — "db"; локально без докера ставь localhost.
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Celery / Redis ----------------------------------------------------------
# В docker compose имя сервиса брокера — "redis"; локально — localhost.
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# --- Почта (уведомления алертов) ---------------------------------------------
# По умолчанию письма печатаются в консоль (ничего реально не отправляется).
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@pricetracker.local

# --- Логирование / домен -----------------------------------------------------
LOG_LEVEL=INFO
# Таймаут внешних HTTP-вызовов (сек).
HTTP_TIMEOUT=10
# Порог нечувствительности тренда (доля): дрожание < eps трендом не считается.
TREND_EPSILON=0.005
